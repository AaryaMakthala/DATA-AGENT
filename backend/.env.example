# ---------------------------------------------------------------------------
# AI Data Analyst Agent -- backend environment configuration
#
# Copy this file to `.env` and fill in the values. `.env` is git-ignored and
# must never be committed. In production, prefer injecting these through your
# platform's secrets manager (Render/Railway/AWS Secrets Manager/etc.) rather
# than a file on disk.
# ---------------------------------------------------------------------------

# --- LLM provider API keys (fallback chain: Groq -> Gemini -> OpenRouter) ----
# At least ONE must be set or every /analyze call fails. Set all three for the
# full fallback chain. These are secrets -- never commit real values.
# Groq is tried first (fastest, most reliable free tier in this deployment).
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# --- CORS -------------------------------------------------------------------
# Comma-separated list of browser origins allowed to call the API. MUST be your
# real frontend origin(s) in production -- never "*" (a wildcard with
# credentials is insecure and rejected by browsers). Include scheme + host
# (+ port if non-standard), no trailing slash.
#   dev:  http://localhost:3000
#   prod: https://app.yourdomain.com
CORS_ALLOW_ORIGINS=http://localhost:3000

# --- Rate limiting ----------------------------------------------------------
# Per-IP sliding-window limits on the two endpoints that trigger real work and
# real LLM spend (/upload, /analyze). Counters are per-process and in-memory;
# behind N worker processes the effective cap is (max * N). For the intended
# single-process deployment that is exact. Set RATE_LIMIT_ENABLED=false only if
# a fronting gateway/CDN already rate-limits.
#
# NOTE: behind a reverse proxy, the client IP is read from the left-most
# X-Forwarded-For entry -- make sure your proxy sets it and that the app is not
# exposed directly (X-Forwarded-For is client-spoofable without a trusted proxy).
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_UPLOAD_MAX=20
RATE_LIMIT_ANALYZE_MAX=5

# --- Upload limits ----------------------------------------------------------
# Largest accepted upload, in megabytes. Enforced while streaming to disk so an
# oversized upload is rejected before it can exhaust memory. Default 100.
MAX_UPLOAD_MB=100

# --- Artifact retention -----------------------------------------------------
# How many hours generated artifacts (uploads, cleaned CSVs, chart PNGs,
# reports) are kept before the startup sweep deletes them. This is also the
# anchor for the privacy policy's data-retention claim. 0 disables the sweep
# (not recommended in production -- the folders then grow without bound).
ARTIFACT_RETENTION_HOURS=24

# --- Storage folders (relative to backend/ unless an absolute path is given) -
UPLOAD_FOLDER=uploads
OUTPUT_FOLDER=outputs
